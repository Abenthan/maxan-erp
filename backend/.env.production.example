# Produccion - copiar a .env en el servidor
DB_HOST=postgres          # nombre del servicio en docker-compose
DB_PORT=5432              # puerto interno del contenedor postgres (siempre 5432)
# El mapeo '5433:5432' en docker-compose.prod.yml es solo para DBeaver desde el host
DB_USER=maxan_user
DB_PASSWORD=cambiar_esta_contrasena
DB_NAME=maxan_erp
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000
NODE_ENV=production
PORT=3000
JWT_SECRET=generar_un_secreto_aleatorio_con_node_-e_console.log(require("crypto").randomBytes(32).toString("hex"))
JWT_EXPIRES_IN=8h
CORS_ORIGIN=https://erp.maxansistemas.com
